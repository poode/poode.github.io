---
import Base from '../layouts/Base.astro';

const lang = 'en';
---

<Base lang={lang}>
  <main class="flex min-h-[70vh] items-center justify-center">
    <div class="container-content text-center">
      <p class="text-7xl font-bold tracking-tight text-accent">404</p>
      <h1 class="mt-4 text-2xl font-semibold text-neutral-900 dark:text-white">Page not found</h1>
      <p class="mt-2 text-neutral-600 dark:text-neutral-400">
        The page you are looking for doesn’t exist or has moved.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-accent-fg transition hover:bg-accent-600"
      >
        Back home
      </a>
    </div>
  </main>
</Base>
