---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/utils';
import { profile } from '../data/profile';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden">
  <!-- animated aurora backdrop -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -left-24 -top-32 h-[28rem] w-[28rem] rounded-full bg-accent/25 blur-3xl animate-float-slow dark:bg-accent/15"></div>
    <div class="absolute -right-20 top-10 h-[24rem] w-[24rem] rounded-full bg-violet-400/20 blur-3xl animate-aurora dark:bg-violet-500/10"></div>
    <div class="absolute bottom-[-8rem] left-1/3 h-[22rem] w-[22rem] rounded-full bg-sky-400/20 blur-3xl animate-float dark:bg-sky-500/10"></div>
  </div>

  <div class="container-content py-20 sm:py-28 lg:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <span
        class="reveal inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-neutral-50/80 px-3 py-1 text-xs font-medium text-neutral-600 backdrop-blur dark:border-neutral-800 dark:bg-neutral-900/80 dark:text-neutral-400"
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        {t('hero.availability')}
      </span>

      <h1
        class="reveal reveal-scale gradient-text animate-gradient-x mt-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-7xl"
        style="--reveal-delay: 80ms"
      >
        {profile.name[lang]}
      </h1>
      <p class="reveal mt-3 text-lg font-medium text-accent sm:text-xl" style="--reveal-delay: 180ms">
        {profile.title[lang]}
      </p>

      <p
        class="reveal mx-auto mt-6 max-w-2xl text-base leading-relaxed text-neutral-600 sm:text-lg dark:text-neutral-400"
        style="--reveal-delay: 280ms"
      >
        {profile.tagline[lang]}
      </p>

      <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3" style="--reveal-delay: 380ms">
        <a
          href="#projects"
          class="group inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-accent-fg shadow-lg shadow-accent/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-accent-600 hover:shadow-xl hover:shadow-accent/30"
        >
          {t('hero.cta.projects')}
          <Icon name="arrow" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 rtl:group-hover:-translate-x-1" />
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-lg border border-neutral-300 px-5 py-2.5 text-sm font-semibold text-neutral-700 transition-all duration-300 hover:-translate-y-0.5 hover:border-neutral-400 hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-900"
        >
          {t('hero.cta.contact')}
        </a>
      </div>

      <div class="reveal mt-10 flex items-center justify-center gap-4" style="--reveal-delay: 480ms">
        {
          profile.socials.map((s) => (
            <a
              href={s.href}
              target={s.icon === 'mail' ? undefined : '_blank'}
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
              class="text-neutral-500 transition-all duration-300 hover:-translate-y-1 hover:scale-110 hover:text-accent dark:text-neutral-500 dark:hover:text-accent-400"
            >
              <Icon name={s.icon} class="h-5 w-5" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
