    </svg>
  )
}
{
  name === 'arrow' && (
    <svg class={`${className} rtl:-scale-x-100`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  )
}
{
  name === 'code' && (
