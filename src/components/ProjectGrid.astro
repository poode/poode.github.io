---
import ProjectCard from './ProjectCard.astro';
import { useTranslations } from '../i18n/utils';
import { projects, groupOrder, groupKey } from '../data/projects';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="projects" class="border-t border-neutral-100 py-20 sm:py-24 dark:border-neutral-900">
  <div class="container-content">
    <div class="max-w-3xl">
      <h2 class="reveal section-heading">{t('projects.heading')}</h2>
      <p class="reveal mt-4 text-base text-neutral-600 sm:text-lg dark:text-neutral-400">
        {t('projects.subheading')}
      </p>
    </div>

    <div class="mt-12 space-y-14">
      {
        groupOrder.map((group) => {
          const groupProjects = projects.filter((p) => p.group === group);
          if (!groupProjects.length) return null;
          return (
            <div>
              <h3 class="reveal text-sm font-semibold uppercase tracking-wider text-neutral-500 dark:text-neutral-500">
                {t(groupKey[group])}
              </h3>
              <div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {groupProjects.map((project, i) => (
                  <ProjectCard project={project} lang={lang} index={i} />
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <p
      class="reveal mt-12 flex items-center gap-3 border-t border-neutral-100 pt-6 text-sm italic text-neutral-500 dark:border-neutral-900 dark:text-neutral-500"
    >
      <span aria-hidden="true" class="text-accent">＋</span>
      {t('projects.more')}
    </p>
  </div>
</section>
