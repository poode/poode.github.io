# Development container for the Astro portfolio.
# Production builds happen in CI (GitHub Actions), not here.
FROM node:22-alpine

WORKDIR /app

# Install deps first for better layer caching.
COPY package.json ./
RUN npm install

# Source is bind-mounted at runtime (see docker-compose.yml) for hot reload.
COPY . .

EXPOSE 4321

CMD ["npm", "run", "dev"]
